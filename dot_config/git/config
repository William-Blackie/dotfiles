
[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = current

[pull]
	rebase = false

[fetch]
	prune = true

[include]
	path = ~/.config/delta/catppuccin.gitconfig
	path = ~/.config/git/local.gitconfig
	path = ~/.config/git/default.gitconfig

[rerere]
    enabled = true
    autoupdate = true

[core]
	editor = nvim
	autocrlf = input
	excludesfile = ~/.config/git/ignore
	ignorecase = true
	pager = delta

[includeIf "gitdir:~/Projects/work/"]
	path = ~/.config/git/work.gitconfig

[alias]
	# Short commands
	st = status
	co = checkout
	br = branch
	cm = commit
	lg = log --oneline --graph --decorate --all
	czc = "!f() { cz commit \"$@\"; }; f"
	cza = "!f() { cz commit -- --amend --allow-empty \"$@\"; }; f"
	czr = "!f() { cz commit --retry \"$@\"; }; f"
	czn = "!f() { cz bump --get-next \"$@\"; }; f"
	czbd = "!f() { cz bump --dry-run --changelog \"$@\"; }; f"
	czb = "!f() { cz bump --changelog \"$@\"; }; f"

	# Useful aliases
	unstage = reset HEAD --
	last = log -1 HEAD
	visual = !gitk

	# Show files ignored by git
	ignored = ls-files --others --ignored --exclude-standard

	# Pretty log
	hist = log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short

	# Show diff of last commit
	dlc = diff --cached HEAD^

	# Undo last commit
	undo = reset --soft HEAD^
	wt = !wt
	tags-reset = "!f(){ remote=\"${1:-origin}\"; tags=\"$(git tag -l)\"; if [ -n \"$tags\" ]; then printf \"%s\\n\" \"$tags\" | xargs -n 1 git tag -d >/dev/null 2>&1; fi; git fetch \"$remote\" --tags --prune --prune-tags; }; f"

[color]
	ui = auto

[diff]
	tool = nvimdiff

[merge]
	tool = nvimdiff

[interactive]
	diffFilter = delta --color-only

[delta]
	features = catppuccin-mocha
	navigate = true
	line-numbers = true
	side-by-side = true
	hyperlinks = true

[url "git@github.com:"]
	insteadOf = https://github.com/


[commit]
	template = ~/.config/git/commit-template.txt

[credential]
	helper =
	helper = /usr/local/share/gcm-core/git-credential-manager

[credential "https://dev.azure.com"]
	useHttpPath = true

[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

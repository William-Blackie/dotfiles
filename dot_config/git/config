
[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = current
    followTags = true

[pull]
    rebase = true

[rebase]
    autoStash = true
    autoSquash = true
    updateRefs = true


[fetch]
    prune = true
    pruneTags = true
    all = true

[branch]
    sort = -committerdate

[tag]
    sort = version:refname

[commit]
    template = ~/.config/git/commit-template.txt
    verbose = true

[diff]
    algorithm = histogram
    renames = true
    mnemonicPrefix = true
    colorMoved = plain

[rerere]
    enabled = true
    autoupdate = true

[core]
	editor = nvim
	autocrlf = input
	excludesfile = ~/.config/git/ignore
	ignorecase = true
	pager = delta

[help]
    autocorrect = prompt

[alias]
	# Short commands
	st = status
	co = checkout
	br = branch
	cm = commit
	lg = log --oneline --graph --decorate --all
	czc = "!f() { cz commit \"$@\"; }; f"
	cza = "!f() { cz commit -- --amend --allow-empty \"$@\"; }; f"
	czr = "!f() { cz commit --retry \"$@\"; }; f"
	czn = "!f() { cz bump --get-next \"$@\"; }; f"
	czbd = "!f() { cz bump --dry-run --changelog \"$@\"; }; f"
	czb = "!f() { cz bump --changelog \"$@\"; }; f"

	# Useful aliases
	unstage = reset HEAD --
	last = log -1 HEAD
	visual = !gitk

	# Show files ignored by git
	ignored = ls-files --others --ignored --exclude-standard

	# Pretty log
	hist = log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short

	# Show diff of last commit
	dlc = diff --cached HEAD^

	# Undo last commit
	undo = reset --soft HEAD^
	wt = !wt
	tags-reset = "!f(){ remote=\"${1:-origin}\"; tags=\"$(git tag -l)\"; if [ -n \"$tags\" ]; then printf \"%s\\n\" \"$tags\" | xargs -n 1 git tag -d >/dev/null 2>&1; fi; git fetch \"$remote\" --tags --prune --prune-tags; }; f"

[color]
	ui = auto

[merge]
	tool = nvimdiff
	conflictstyle = zdiff3

[mergetool]
	# After performing a merge, the original file with conflict markers can
	# be saved as a file with a .orig extension. I do not want that
	keepBackup = false
	# Don't prompt before each invocation of the merge resolution program
	prompt = false
	# Use temporary directory for cleaner file names
	writeToTemp = true

[mergetool "nvimdiff"]
	# Multi-tab layout: 1) REMOTE only, 2) REMOTE vs LOCAL, 3) 4-way view
	# Use ':cquit' to exit with an error code of 1 to abort the merge
	# Use ':wqall' to accept the changes
    # layout = "@REMOTE + REMOTE,LOCAL + REMOTE,MERGED,LOCAL / BASE"

[interactive]
	diffFilter = delta --color-only

[delta]
	features = catppuccin-mocha
	navigate = true
	line-numbers = true
	side-by-side = true
	hyperlinks = true
	tabs = 2
	navigate = true

[user]
    name = William Blackie

[user]
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIONHSxUVGSX1xgPZ+jyicMOJkF45tcdkq2IZCgIMrpc7

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
  gpgsign = true


[include]
    path = ~/.config/delta/catppuccin.gitconfig
    path = ~/.config/git/local.gitconfig
    path = ~/.config/git/default.gitconfig

[includeIf "gitdir:~/Projects/work/"]
    path = ~/.config/git/work.gitconfig


[credential]
	helper =
	helper = /usr/local/share/gcm-core/git-credential-manager


[url "git@github.com:"]
    insteadOf = https://github.com/

{
  "name": "dotfiles",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "check": "make check",
    "format": "make format",
    "format:check": "make format-check",
    "lint": "make lint",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{md,json,yml,yaml}": "prettier --write --ignore-unknown --config dot_prettierrc.toml",
    "*.md": "markdownlint-cli2 --config dot_markdownlint.toml",
    "*.toml": [
      "taplo format --config taplo.toml",
      "taplo lint --config taplo.toml --no-schema"
    ],
    "*.lua": "stylua --config-path dot_config/exact_nvim/stylua.toml",
    "*.sh": [
      "shfmt -w -i 4 -ci -bn",
      "shellcheck"
    ],
    "dot_zshenv": [
      "shfmt -w -i 4 -ci -bn",
      "shellcheck"
    ],
    "{dot_config/zsh/dot_zprofile,dot_config/zsh/dot_zshenv,dot_config/zsh/dot_zshrc,dot_config/exact_fzf/fzf.zsh,dot_local/share/omzsh/**/*.zsh}": [
      "shfmt -w -ln zsh -i 2",
      "zsh -n"
    ]
  },
  "devDependencies": {
    "@johnnymorganz/stylua-bin": "^2.5.2",
    "@taplo/cli": "^0.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3"
  }
}

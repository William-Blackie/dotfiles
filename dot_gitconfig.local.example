# Machine-local git identity and credentials.
# Copy to ~/.gitconfig.local and fill in your details.
# This file is NOT tracked by version control.

[user]
	email = you@example.com
	name = Your Name

# Credential helpers (uncomment as needed)
# [credential]
# 	helper = manager
# 	helper = /usr/local/share/gcm-core/git-credential-manager

# Azure DevOps (uncomment if needed)
# [credential "https://dev.azure.com"]
# 	useHttpPath = true

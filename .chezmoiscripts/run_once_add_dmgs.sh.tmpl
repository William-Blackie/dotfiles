#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}

set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$HOME/bin:$PATH"

# Check if an app is already installed
is_app_installed() {
    local app_name="$1"
    [[ -d "/Applications/${app_name}.app" ]] || [[ -d "$HOME/Applications/${app_name}.app" ]]
}

# Install a DMG from URL
install_dmg() {
    local name="$1"
    local url="$2"
    local app_name="$3"
    local temp_dir
    local dmg_path
    local mount_point

    if is_app_installed "$app_name"; then
        echo "  ✓ ${app_name} is already installed"
        return 0
    fi

    echo "  Installing ${app_name} from DMG..."

    temp_dir=$(mktemp -d)
    dmg_path="${temp_dir}/$(basename "$url" | sed 's/[?&].*$//').dmg"

    # Download DMG (handle redirects)
    if ! curl -fsSL -o "$dmg_path" "$url" 2>/dev/null; then
        echo "  ✗ Failed to download ${name}"
        rm -rf "$temp_dir"
        return 1
    fi

    # Verify it's a DMG
    if [[ ! -f "$dmg_path" ]] || [[ "$(file -b "$dmg_path" 2>/dev/null | head -1)" != *"zlib compressed"* ]] && [[ "$(file -b "$dmg_path" 2>/dev/null | head -1)" != *"Apple Driver Map"* ]] && [[ "$(file -b "$dmg_path" 2>/dev/null | head -1)" != *"data"* ]]; then
        echo "  ✗ Downloaded file for ${name} is not a valid DMG"
        rm -rf "$temp_dir"
        return 1
    fi

    # Mount DMG
    mount_point=$(hdiutil attach "$dmg_path" -nobrowse -readonly 2>/dev/null | tail -n 1 | awk '{$1=$2=""; print $0}' | sed 's/^ *//')
    if [[ -z "$mount_point" ]]; then
        echo "  ✗ Failed to mount DMG for ${name}"
        rm -rf "$temp_dir"
        return 1
    fi

    # Find the .app bundle
    local app_bundle
    app_bundle=$(find "$mount_point" -maxdepth 1 -name "*.app" -print -quit 2>/dev/null)

    if [[ -z "$app_bundle" ]]; then
        # Try one level deeper
        app_bundle=$(find "$mount_point" -maxdepth 2 -name "*.app" -print -quit 2>/dev/null)
    fi

    if [[ -n "$app_bundle" ]]; then
        # Copy to Applications
        cp -R "$app_bundle" "/Applications/"
        echo "  ✓ Installed ${app_name}"
    else
        echo "  ✗ No .app bundle found in DMG for ${name}"
    fi

    # Unmount and cleanup
    hdiutil detach "$mount_point" -quiet 2>/dev/null || true
    rm -rf "$temp_dir"
}

# Install DMGs
{{- if .packages.darwin.dmgs }}
echo "Installing DMG applications..."
{{- range $key, $value := .packages.darwin.dmgs }}
install_dmg "{{ $key }}" "{{ $value.url }}" "{{ $value.app_name }}"
{{- end }}
{{- end }}

{{- end }}

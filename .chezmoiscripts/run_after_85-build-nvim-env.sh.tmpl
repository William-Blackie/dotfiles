#!/usr/bin/env bash
set -euo pipefail

PYTHON_VERSION="3.12"
NODE_MAJOR="24"
PNPM_VERSION="11.1.2"
RUBY_GEM_VERSION="0.10.0"
PERL_MODULE="Neovim::Ext"

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
XDG_DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"

MANIFEST_ROOT="${SOURCE_DIR}/dot_config/exact_nvim/data/virtualenvs"
ENV_ROOT="${XDG_DATA_HOME}/nvim/env"

PYTHON_MANIFEST_DIR="${MANIFEST_ROOT}/python"
NODE_MANIFEST_DIR="${MANIFEST_ROOT}/node"
PYTHON_ENV_DIR="${ENV_ROOT}/python"
NODE_ENV_DIR="${ENV_ROOT}/node"
RUBY_ENV_DIR="${ENV_ROOT}/ruby"
PERL_ENV_DIR="${ENV_ROOT}/perl"
NODE_BIN_DIR="${NODE_ENV_DIR}/bin"
RUBY_BIN_DIR="${RUBY_ENV_DIR}/bin"
RUBY_GEM_BIN_DIR="${RUBY_ENV_DIR}/gems/bin"
PERL_BIN_DIR="${PERL_ENV_DIR}/bin"

has_cmd() {
    command -v "$1" >/dev/null 2>&1
}

brew_prefix() {
    local formula="$1"

    has_cmd brew || return 1
    brew --prefix "$formula" 2>/dev/null
}

sync_file() {
    local src="$1"
    local dest="$2"

    if [[ -f "$src" ]]; then
        cp -p "$src" "$dest"
    else
        rm -f "$dest"
    fi
}

write_ruby_host_wrapper() {
    local ruby_bin="$1"
    local wrapper="$2"

    cat >"$wrapper" <<EOF
#!/usr/bin/env bash
set -euo pipefail
export GEM_HOME="${RUBY_ENV_DIR}/gems"
export GEM_PATH="${RUBY_ENV_DIR}/gems"
export PATH="$(dirname "$ruby_bin"):${RUBY_GEM_BIN_DIR}:\${PATH}"
exec "${RUBY_GEM_BIN_DIR}/neovim-ruby-host" "\$@"
EOF
    chmod 0755 "$wrapper"
}

write_perl_wrapper() {
    local perl_bin="$1"
    local wrapper="$2"
    local perl_lib="${PERL_ENV_DIR}/lib/perl5"

    cat >"$wrapper" <<EOF
#!/usr/bin/env bash
set -euo pipefail
export PERL5LIB="${perl_lib}:\${PERL5LIB:-}"
exec "${perl_bin}" "\$@"
EOF
    chmod 0755 "$wrapper"
}

write_node_bin_wrapper() {
    local target="$1"
    local wrapper="$2"
    local version="$3"

    rm -f "$wrapper"
    cat >"$wrapper" <<EOF
#!/usr/bin/env bash
set -euo pipefail
case "\${1:-}" in
    --version|-v)
        printf '%s\n' "${version}"
        ;;
    *)
        exec "${NODE_BIN_DIR}/node" "${target}" "\$@"
        ;;
esac
EOF
    chmod 0755 "$wrapper"
}

sync_python_env() {
    [[ -f "${PYTHON_MANIFEST_DIR}/pyproject.toml" ]] || return 0

    if ! has_cmd uv; then
        echo "Skipping Neovim Python env build: missing required command: uv"
        return 0
    fi

    echo "Syncing Neovim Python env with uv at ${PYTHON_ENV_DIR}..."
    UV_PROJECT_ENVIRONMENT="${PYTHON_ENV_DIR}/.venv" uv sync \
        --project "$PYTHON_MANIFEST_DIR" \
        --python "$PYTHON_VERSION" \
        --no-install-project
}

sync_node_env() {
    [[ -f "${NODE_MANIFEST_DIR}/package.json" && -f "${NODE_MANIFEST_DIR}/pnpm-lock.yaml" ]] || return 0

    NVM_DIR="${NVM_DIR:-${XDG_DATA_HOME}/nvm}"
    if [[ -s "${NVM_DIR}/nvm.sh" ]]; then
        # shellcheck disable=SC1091
        . "${NVM_DIR}/nvm.sh"
    elif nvm_prefix="$(brew_prefix nvm)" && [[ -s "${nvm_prefix}/nvm.sh" ]]; then
        # shellcheck disable=SC1090,SC1091
        . "${nvm_prefix}/nvm.sh"
    fi

    if ! has_cmd nvm; then
        echo "Skipping Neovim Node env build: missing required command: nvm"
        return 0
    fi

    nvm install "$NODE_MAJOR"
    nvm use "$NODE_MAJOR" >/dev/null

    node_major="$(node -p 'process.versions.node.split(".")[0]')"
    if [[ "$node_major" != "$NODE_MAJOR" ]]; then
        echo "Skipping Neovim Node env build: expected Node ${NODE_MAJOR}.x, found $(node --version)."
        return 0
    fi

    if ! has_cmd pnpm; then
        if ! has_cmd corepack; then
            echo "Skipping Neovim Node env build: missing required command: pnpm or corepack"
            return 0
        fi
        corepack prepare "pnpm@${PNPM_VERSION}" --activate
    fi

    sync_file "${NODE_MANIFEST_DIR}/package.json" "${NODE_ENV_DIR}/package.json"
    sync_file "${NODE_MANIFEST_DIR}/pnpm-lock.yaml" "${NODE_ENV_DIR}/pnpm-lock.yaml"
    sync_file "${NODE_MANIFEST_DIR}/pnpm-workspace.yaml" "${NODE_ENV_DIR}/pnpm-workspace.yaml"

    echo "Syncing Neovim Node env with pnpm at ${NODE_ENV_DIR}..."
    pnpm --dir "$NODE_ENV_DIR" install --frozen-lockfile

    mkdir -p "$NODE_BIN_DIR"
    ln -sfn "$(command -v node)" "${NODE_BIN_DIR}/node"
    ln -sfn "${NODE_ENV_DIR}/node_modules/neovim/bin/cli.js" "${NODE_BIN_DIR}/neovim-node-host"
    write_node_bin_wrapper "${NODE_ENV_DIR}/node_modules/obsidian-headless/cli.js" "${NODE_BIN_DIR}/ob" "0.0.8"
}

sync_ruby_env() {
    local ruby_prefix ruby_bin gem_bin

    if ! ruby_prefix="$(brew_prefix ruby)" || [[ ! -x "${ruby_prefix}/bin/ruby" || ! -x "${ruby_prefix}/bin/gem" ]]; then
        echo "Skipping Neovim Ruby env build: missing Homebrew ruby"
        return 0
    fi

    ruby_bin="${ruby_prefix}/bin/ruby"
    gem_bin="${ruby_prefix}/bin/gem"

    echo "Syncing Neovim Ruby env at ${RUBY_ENV_DIR}..."
    GEM_HOME="${RUBY_ENV_DIR}/gems" \
        GEM_PATH="${RUBY_ENV_DIR}/gems" \
        PATH="$(dirname "$ruby_bin"):${RUBY_GEM_BIN_DIR}:${PATH}" \
        "$gem_bin" install logger \
        --no-document
    GEM_HOME="${RUBY_ENV_DIR}/gems" \
        GEM_PATH="${RUBY_ENV_DIR}/gems" \
        PATH="$(dirname "$ruby_bin"):${RUBY_GEM_BIN_DIR}:${PATH}" \
        "$gem_bin" install neovim \
        --version "$RUBY_GEM_VERSION" \
        --no-document

    mkdir -p "$RUBY_BIN_DIR"
    write_ruby_host_wrapper "$ruby_bin" "${RUBY_BIN_DIR}/neovim-ruby-host"
}

sync_perl_env() {
    local perl_prefix perl_bin cpanm_prefix cpanm_bin

    if ! perl_prefix="$(brew_prefix perl)" || [[ ! -x "${perl_prefix}/bin/perl" ]]; then
        echo "Skipping Neovim Perl env build: missing Homebrew perl"
        return 0
    fi

    if cpanm_prefix="$(brew_prefix cpanminus)" && [[ -x "${cpanm_prefix}/bin/cpanm" ]]; then
        cpanm_bin="${cpanm_prefix}/bin/cpanm"
    elif has_cmd cpanm; then
        cpanm_bin="$(command -v cpanm)"
    else
        echo "Skipping Neovim Perl env build: missing cpanm"
        return 0
    fi

    perl_bin="${perl_prefix}/bin/perl"
    echo "Syncing Neovim Perl env at ${PERL_ENV_DIR}..."
    PERL_CPANM_HOME="${PERL_ENV_DIR}/cpanm" \
        "$cpanm_bin" -L "$PERL_ENV_DIR" -n App::cpanminus "$PERL_MODULE"

    mkdir -p "$PERL_BIN_DIR"
    write_perl_wrapper "$perl_bin" "${PERL_BIN_DIR}/perl"
}

mkdir -p "$PYTHON_ENV_DIR" "$NODE_ENV_DIR" "$RUBY_ENV_DIR" "$PERL_ENV_DIR"

sync_python_env
sync_node_env
sync_ruby_env
sync_perl_env

echo "Neovim envs are ready under ${ENV_ROOT}."
